# Backend (QuotVid API) — used from Next.js Route Handlers (server-only) where possible.
QUOTVID_API_URL=https://api.quotvid.example

# Same origin for client-side calls only if you expose a public URL (prefer server proxy).
NEXT_PUBLIC_QUOTVID_API_URL=

# Public API URL used by the funnel form submit (client-side fetch to backend).
NEXT_PUBLIC_API_URL=https://api.quotvid.com

# Main app URL — used for "Sign in" link when user already has an account.
NEXT_PUBLIC_APP_URL=https://app.quotvid.com

# Reserved / unused — the funnel form does not send a secret; signup is POST /api/funnel/signup with CORS only.
# FUNNEL_API_SECRET=

# Optional: main marketing site URL for 404 “Go to QuotVid” (defaults to https://quotvid.com).
NEXT_PUBLIC_MARKETING_SITE_URL=https://quotvid.com

# Optional: named funnel slug for multi-funnel routing (defaults per route).
NEXT_PUBLIC_FUNNEL_SLUG=pinterest

# Optional: CDN base for hero mosaic MP4s when using relative paths like /assets/foo.mp4.
# Full https://… URLs in funnel-models skip this. Leave empty if all clips are absolute URLs.
# Example: https://your-bucket.r2.dev/funnel-hero
NEXT_PUBLIC_FUNNEL_VIDEO_CDN_BASE=
